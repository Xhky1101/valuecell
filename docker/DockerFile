# 1. Use the official uv + python image.
# This ALREADY contains 'uv', so we don't need to copy it from another image.
FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

# 2. Configure uv for Docker environments.
# - UV_COMPILE_BYTECODE: compiles python files to speed up startup.
# - UV_LINK_MODE: uses 'copy' instead of hardlinks, which is safer for Docker layers.
ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy

WORKDIR /app

# 3. Install system dependencies.
# We use a cache mount for apt to speed up rebuilds.
# Using a prefixed ID to satisfy strict platform requirements.
RUN --mount=type=cache,id=__app_cache-apt,target=/var/cache/apt \
    apt-get update && apt-get install -y curl \
    && rm -rf /var/lib/apt/lists/*

# 4. Install python dependencies.
# We mount the cache at the default location for uv.
# Using a prefixed ID for uv cache.
RUN --mount=type=cache,id=__app_cache-uv,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    uv sync --frozen --no-install-project

# 5. Copy the rest of the application code.
COPY . /app

# 6. Install the project itself (if it has an installable package)
# or just sync the environment to ensure everything is ready.
RUN --mount=type=cache,id=__app_cache-uv,target=/root/.cache/uv \
    uv sync --frozen

# 7. Add the virtual environment to the PATH.
# This allows you to run "python" directly without "uv run", which is often cleaner
# for production containers and signals.
ENV PATH="/app/.venv/bin:$PATH"

EXPOSE 8000

# 8. Run the application.
# Since we added .venv to PATH, we can just call python directly.
CMD ["python", "main.py", "--host", "0.0.0.0", "--port", "8000"]
