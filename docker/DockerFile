# 1. Base Image
# Use the official uv + python image.
FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

# 2. Configure uv for Docker environments.
ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy

WORKDIR /app

# Add a build argument that Railway automatically populates with the Service ID.
# This is crucial for using cache mounts on Railway.
ARG RAILWAY_SERVICE_ID

# 3. Install system dependencies.
RUN --mount=type=cache,id=s/${RAILWAY_SERVICE_ID}-apt-cache,target=/var/cache/apt \
    apt-get update && apt-get install -y curl \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# 4. Copy dependency files first for better caching
COPY uv.lock pyproject.toml ./

# 5. Install Python dependencies
RUN --mount=type=cache,id=s/${RAILWAY_SERVICE_ID}-uv-cache,target=/root/.cache/uv \
    uv sync --frozen --no-install-project

# 6. Copy the rest of the application code.
COPY . /app

# 7. Install the project
RUN --mount=type=cache,id=s/${RAILWAY_SERVICE_ID}-uv-cache,target=/root/.cache/uv \
    uv sync --frozen

# 8. Set up the Environment
# Add the virtual environment to the PATH.
ENV PATH="/app/.venv/bin:$PATH"

# 9. Security: Create and switch to a non-root user
# This is a critical security best practice.
RUN useradd -m appuser
# Ensure the non-root user owns the app directory
RUN chown -R appuser:appuser /app
USER appuser

EXPOSE 8000

# 10. Run the application as the non-root user.
CMD ["python", "main.py", "--host", "0.0.0.0", "--port", "8000"]
